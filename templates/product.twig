{% extends 'layout/theme.twig' %}

{% block title %}{{ product.name }} — {{ store.name }}{% endblock %}
{% block meta_description %}{{ product.description | striptags | truncate(160) }}{% endblock %}

{% block content %}

  {# ═══════════════════════════════════════════════════════
     PRODUCT PAGE — Aesop-style editorial layout
     Left: product gallery. Right: product details.
  ══════════════════════════════════════════════════════ #}
  <section class="product-page container" aria-label="{{ product.name }}">

    {# Breadcrumb #}
    <nav class="breadcrumb" aria-label="{{ 'product.breadcrumb' | t }}">
      <ol class="breadcrumb__list" role="list">
        <li><a href="{{ routes.root_url }}">{{ 'nav.home' | t }}</a></li>
        <li aria-hidden="true" class="breadcrumb__sep">—</li>
        <li><a href="{{ routes.products_url }}">{{ 'nav.shop' | t }}</a></li>
        <li aria-hidden="true" class="breadcrumb__sep">—</li>
        <li aria-current="page">{{ product.name }}</li>
      </ol>
    </nav>

    <div class="product-page__grid">

      {# ── Gallery ── #}
      <div class="product-gallery">
        <div class="product-gallery__main">
          {% if product.image %}
          <img
            id="gallery-main-img"
            src="{{ product.image | image({ width: 900, height: 1100, crop: 'center' }) }}"
            alt="{{ product.name }}"
            width="900"
            height="1100"
            loading="eager"
            class="product-gallery__img"
          />
          {% else %}
          <div class="product-gallery__img product-gallery__img--placeholder" aria-hidden="true"></div>
          {% endif %}
        </div>

        {% if product.images | length > 1 %}
        <div class="product-gallery__thumbs" role="list" aria-label="{{ 'product.gallery' | t }}">
          {% for image in product.images | slice(0, 5) %}
          <button
            class="product-gallery__thumb{% if loop.first %} is-active{% endif %}"
            data-src="{{ image | image({ width: 900, height: 1100, crop: 'center' }) }}"
            aria-label="{{ 'product.image_n' | t({ n: loop.index }) }}"
            role="listitem"
          >
            <img
              src="{{ image | image({ width: 120, height: 150, crop: 'center' }) }}"
              alt=""
              width="120"
              height="150"
              loading="lazy"
            />
          </button>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      {# ── Product info ── #}
      <div class="product-info">

        {% if product.category %}
        <p class="product-info__category">{{ product.category.name }}</p>
        {% endif %}

        <h1 class="product-info__title">{{ product.name }}</h1>

        {# Price #}
        <div class="product-info__price" aria-live="polite">
          {% if product.is_on_sale %}
            <del class="product-info__price-old">{{ product.price.regular | money }}</del>
            <ins class="product-info__price-sale">{{ product.price.current | money }}</ins>
            {% if product.discount_percentage %}
            <span class="product-info__badge">{{ product.discount_percentage }}٪-</span>
            {% endif %}
          {% else %}
            <span class="product-info__price-current">{{ product.price.current | money }}</span>
          {% endif %}
        </div>

        <div class="hairline hairline--my" role="separator"></div>

        {# Short description #}
        {% if product.short_description %}
        <div class="product-info__short-desc">{{ product.short_description }}</div>
        {% endif %}

        {# Add to cart — Salla web component #}
        <div class="product-info__atc">
          <salla-add-to-cart
            product-id="{{ product.id }}"
            display="block"
          ></salla-add-to-cart>
        </div>

        {# Wishlist + share #}
        <div class="product-info__actions">
          <salla-add-to-wishlist product-id="{{ product.id }}"></salla-add-to-wishlist>
          <salla-share></salla-share>
        </div>

        <div class="hairline hairline--my" role="separator"></div>

        {# Full description #}
        {% if product.description %}
        <details class="product-info__details" open>
          <summary class="product-info__details-trigger">{{ 'product.description' | t }}</summary>
          <div class="product-info__details-body prose">
            {{ product.description | raw }}
          </div>
        </details>
        {% endif %}

        {# Additional info: SKU, availability #}
        <dl class="product-info__meta">
          {% if product.sku %}
          <div>
            <dt>{{ 'product.sku' | t }}</dt>
            <dd>{{ product.sku }}</dd>
          </div>
          {% endif %}
          <div>
            <dt>{{ 'product.availability' | t }}</dt>
            <dd>
              {% if product.is_available %}
                {{ 'product.in_stock' | t }}
              {% else %}
                {{ 'product.out_of_stock' | t }}
              {% endif %}
            </dd>
          </div>
        </dl>

      </div>
    </div>

  </section>

  {# ═══════════════════════════════════════════════════════
     RELATED PRODUCTS
  ══════════════════════════════════════════════════════ #}
  {%
    set related = store.products({
      limit:    4,
      category: product.category.id,
      exclude:  product.id
    })
  %}

  {% if related | length > 0 %}
  <section class="related-products" aria-labelledby="related-heading">
    <div class="container">
      <div class="section-head">
        <h2 class="section-head__title" id="related-heading">{{ 'product.related' | t }}</h2>
        <div class="hairline" role="separator"></div>
      </div>

      <ul class="product-grid product-grid--4col" role="list">
        {% for p in related %}
        <li class="product-card" role="listitem">
          <a class="product-card__image-link" href="{{ p.url }}" tabindex="-1" aria-hidden="true">
            <div class="product-card__image-wrap">
              {% if p.image %}
              <img
                src="{{ p.image | image({ width: 480, height: 600, crop: 'center' }) }}"
                alt="{{ p.name }}"
                width="480"
                height="600"
                loading="lazy"
                class="product-card__image"
              />
              {% else %}
              <div class="product-card__image product-card__image--placeholder" aria-hidden="true"></div>
              {% endif %}
            </div>
          </a>
          <div class="product-card__body">
            <a href="{{ p.url }}" class="product-card__name-link">
              <h3 class="product-card__name">{{ p.name }}</h3>
            </a>
            <div class="product-card__footer">
              <span class="product-card__price">{{ p.price.current | money }}</span>
            </div>
          </div>
        </li>
        {% endfor %}
      </ul>
    </div>
  </section>
  {% endif %}

{% endblock %}

{% block scripts_extra %}
<script>
  // Gallery thumbnail switcher
  document.querySelectorAll('.product-gallery__thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var main = document.getElementById('gallery-main-img');
      if (main) main.src = this.dataset.src;
      document.querySelectorAll('.product-gallery__thumb').forEach(function(b) {
        b.classList.remove('is-active');
      });
      this.classList.add('is-active');
    });
  });
</script>
{% endblock %}
