{% extends "layouts.master" %}

{% block title %}{{ product.name }} | {{ store.name }}{% endblock %}
{% block meta_description %}{{ product.description|striptags|default(product.name) }}{% endblock %}

{% block content %}
  <section class="product-page container" aria-label="{{ product.name }}">
    {% component breadcrumbs %}

    <div class="product-page__grid">
      <div class="product-gallery">
        <div class="product-gallery__main">
          {% if product.image %}
            <img
              id="gallery-main-img"
              class="product-gallery__img"
              src="{{ product.image|image({ width: 900, height: 1100, crop: 'center' }) }}"
              alt="{{ product.name }}">
          {% else %}
            <div class="product-gallery__img product-gallery__img--placeholder" aria-hidden="true"></div>
          {% endif %}
        </div>

        {% if product.images|length > 1 %}
          <div class="product-gallery__thumbs" aria-label="{{ trans('product.gallery') }}">
            {% for image in product.images|slice(0, 5) %}
              <button
                class="product-gallery__thumb{% if loop.first %} is-active{% endif %}"
                type="button"
                data-src="{{ image|image({ width: 900, height: 1100, crop: 'center' }) }}"
                aria-label="{{ trans('product.image_number', { number: loop.index }) }}">
                <img src="{{ image|image({ width: 120, height: 150, crop: 'center' }) }}" alt="">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="product-info">
        {% if product.category %}
          <p class="product-info__category">{{ product.category.name }}</p>
        {% endif %}

        <h1 class="product-info__title">{{ product.name }}</h1>

        <div class="product-info__price">
          {% if product.is_on_sale %}
            <del class="product-info__price-old">{{ product.regular_price|money }}</del>
          {% endif %}
          <span class="product-info__price-current">{{ product.price|money }}</span>
        </div>

        {% component product.offer %}
        {% hook 'product:single.description.start' %}

        {% if product.short_description %}
          <div class="product-info__short-desc">{{ product.short_description }}</div>
        {% endif %}

        <div class="product-info__purchase">
          <salla-add-product product-id="{{ product.id }}"></salla-add-product>
        </div>

        <div class="product-info__actions">
          <salla-social-share></salla-social-share>
        </div>

        {% if product.description %}
          <details class="product-info__details" open>
            <summary class="product-info__details-trigger">{{ trans('product.description') }}</summary>
            <div class="product-info__details-body prose">
              {{ product.description|raw }}
            </div>
          </details>
        {% endif %}

        <dl class="product-info__meta">
          {% if product.sku %}
            <div>
              <dt>{{ trans('product.sku') }}</dt>
              <dd>{{ product.sku }}</dd>
            </div>
          {% endif %}
          <div>
            <dt>{{ trans('product.availability') }}</dt>
            <dd>{{ product.is_available ? trans('product.in_stock') : trans('product.out_of_stock') }}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  {% component comments %}
  {% component product.similar-products %}
{% endblock %}

{% block scripts %}
  {{ parent() }}
  <script>
    document.querySelectorAll('.product-gallery__thumb').forEach(function (button) {
      button.addEventListener('click', function () {
        var main = document.getElementById('gallery-main-img');
        if (!main) return;
        main.src = this.dataset.src;
        document.querySelectorAll('.product-gallery__thumb').forEach(function (thumb) {
          thumb.classList.remove('is-active');
        });
        this.classList.add('is-active');
      });
    });
  </script>
{% endblock %}
