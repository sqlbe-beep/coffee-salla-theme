{% extends "layouts.master" %}

{% block title %}{{ store.name|default('مزن') }}{% endblock %}
{% block meta_description %}{{ store.description|default(trans('home.hero.subtitle')) }}{% endblock %}

{% block content %}
  {% set featured_products = store.products({ limit: 6, sort: 'newest' }) %}

  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero__photo hero__photo--placeholder" aria-hidden="true"></div>
    <div class="hero__scrim" aria-hidden="true"></div>

    <div class="container hero__content">
      <div class="hero__text">
        <p class="hero__eyebrow">{{ trans('home.hero.eyebrow') }}</p>
        <h1 class="hero__title" id="hero-heading">{{ trans('home.hero.title') }}</h1>
        <p class="hero__subtitle">{{ trans('home.hero.subtitle') }}</p>
        <a href="{{ routes.products_url }}" class="cta-btn cta-btn--light">{{ trans('home.hero.cta') }}</a>
      </div>
    </div>
  </section>

  <section class="featured-products" aria-labelledby="products-heading">
    <div class="container">
      <div class="section-head">
        <h2 class="section-head__title" id="products-heading">{{ trans('home.featured.title') }}</h2>
        <div class="hairline" role="separator"></div>
      </div>

      {% if featured_products|length %}
        <ul class="product-grid">
          {% for product in featured_products %}
            <li class="product-card">
              <a class="product-card__image-link" href="{{ product.url }}">
                <div class="product-card__image-wrap">
                  {% if product.image %}
                    <img
                      class="product-card__image"
                      src="{{ product.image|image({ width: 640, height: 800, crop: 'center' }) }}"
                      alt="{{ product.name }}"
                      loading="lazy">
                  {% else %}
                    <div class="product-card__image product-card__image--placeholder" aria-hidden="true"></div>
                  {% endif %}
                </div>
              </a>

              <div class="product-card__body">
                <a class="product-card__name-link" href="{{ product.url }}">
                  <h3 class="product-card__name">{{ product.name }}</h3>
                </a>

                {% if product.short_description %}
                  <p class="product-card__note">{{ product.short_description }}</p>
                {% endif %}

                <div class="product-card__footer">
                  <span class="product-card__price">
                    {% if product.is_on_sale %}
                      <del class="product-card__price-old">{{ product.regular_price|money }}</del>
                    {% endif %}
                    {{ product.price|money }}
                  </span>
                  <a href="{{ product.url }}" class="product-card__link">{{ trans('home.featured.view_product') }}</a>
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="empty-state">{{ trans('home.featured.empty') }}</p>
      {% endif %}
    </div>
  </section>

  <section class="story">
    <div class="story__grid">
      <div class="story__visual">
        <div class="story__image story__image--placeholder" aria-hidden="true"></div>
      </div>
      <div class="story__body">
        <span class="eyebrow">{{ trans('home.story.label') }}</span>
        <h2 class="story__title">{{ trans('home.story.title') }}</h2>
        <div class="story__text">
          <p>{{ trans('home.story.body_1') }}</p>
          <p>{{ trans('home.story.body_2') }}</p>
        </div>
        <a href="{{ routes.products_url }}" class="cta-btn cta-btn--dark">{{ trans('home.story.cta') }}</a>
      </div>
    </div>
  </section>
{% endblock %}
