{% extends "layouts.master" %}
{% block content %}
    {% set featured_products = store.products({ limit: 6, sort: 'newest' }) %}

    <section class="mzn-hero" aria-labelledby="mzn-hero-title">
        <div class="mzn-hero__visual" aria-hidden="true">
            <div class="mzn-hero__grain"></div>
        </div>
        <div class="container mzn-hero__inner">
            <div class="mzn-hero__copy">
                <span class="mzn-eyebrow">مزن | قهوة مختصة</span>
                <h1 id="mzn-hero-title">
                    هدوء التفاصيل
                    <strong>في كل رشفة</strong>
                </h1>
                <p class="mzn-hero__lead">
                    تجربة مزن مصممة لمن يفضّل القهوة المختصة بهوية عربية هادئة،
                    ومختارات منتقاة بعناية، وتقديم بصري يترك مساحة للمنتج والقصة معًا.
                </p>
                <div class="mzn-hero__actions">
                    <a href="{{ routes.products_url }}" class="mzn-button mzn-button--light">اكتشف مختارات مزن</a>
                </div>
            </div>
        </div>
    </section>

    <section class="mzn-section mzn-curation" aria-labelledby="mzn-curation-title">
        <div class="container">
            <div class="mzn-section__header">
                <span class="mzn-eyebrow mzn-eyebrow--dark">مختارات مزن</span>
                <h2 id="mzn-curation-title">اختيارات أقرب إلى الذوق الهادئ</h2>
                <div class="mzn-hairline"></div>
            </div>

            {% if featured_products|length %}
                <div class="mzn-product-grid">
                    {% for product in featured_products %}
                        <article class="mzn-product-card">
                            <a href="{{ product.url }}" class="mzn-product-card__media" aria-label="{{ product.name }}">
                                {% if product.image %}
                                    <img
                                        src="{{ product.image|image({ width: 800, height: 1000, crop: 'center' }) }}"
                                        alt="{{ product.name }}"
                                        class="mzn-product-card__image"
                                        loading="lazy">
                                {% else %}
                                    <div class="mzn-product-card__placeholder" aria-hidden="true"></div>
                                {% endif %}
                            </a>

                            <div class="mzn-product-card__body">
                                <h3 class="mzn-product-card__title">
                                    <a href="{{ product.url }}">{{ product.name }}</a>
                                </h3>
                                {% if product.short_description %}
                                    <p class="mzn-product-card__excerpt">{{ product.short_description }}</p>
                                {% endif %}
                                <div class="mzn-product-card__meta">
                                    <span class="mzn-product-card__price">
                                        {% if product.is_on_sale %}
                                            <del>{{ product.regular_price|money }}</del>
                                        {% endif %}
                                        {{ product.price|money }}
                                    </span>
                                    <a href="{{ product.url }}" class="mzn-product-card__link">عرض المنتج</a>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <p class="mzn-empty">لا توجد منتجات متاحة الآن.</p>
            {% endif %}
        </div>
    </section>

    <section class="mzn-section mzn-story" aria-labelledby="mzn-story-title">
        <div class="mzn-story__panel">
            <div class="mzn-story__image" aria-hidden="true"></div>
            <div class="mzn-story__content">
                <span class="mzn-eyebrow mzn-eyebrow--dark">قصة مزن</span>
                <h2 id="mzn-story-title">هوية هادئة بطابع تحريري راقٍ</h2>
                <p>
                    في مزن نمنح المساحة للنغمة البصرية الهادئة: ألوان دافئة، فراغات واسعة،
                    وعناوين أكثر رهافة لتبقى القهوة في مركز المشهد.
                </p>
                <p>
                    النتيجة واجهة عربية أنيقة تشبه تجربة علامة فاخرة، بلا ازدحام،
                    وبإيقاع بصري مريح يليق بتفاصيل القهوة المختصة.
                </p>
                <a href="{{ routes.products_url }}" class="mzn-button mzn-button--dark">تجربة مزن</a>
            </div>
        </div>
    </section>
{% endblock %}
