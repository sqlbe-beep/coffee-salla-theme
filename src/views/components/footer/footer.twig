<footer class="store-footer mzn-footer">
	<div aria-label="footer" class="store-footer__inner">
		<div class="container grid grid-col-1 lg:grid-cols-6 gap-8 lg:gap-6 mzn-footer__inner">
			<div class="lg:col-span-2 rtl:lg:pl-20 ltr:lg:pr-20 mzn-footer__brand">
				<a href="{{ link('/') }}" class="flex items-center m-0 mzn-footer__wordmark">
					<h3>{{ store.name|default('مزن') }}</h3>
				</a>
				<div class="max-w-sm leading-6 mb-6 mzn-footer__tagline">
					{{ store.description ?: 'قهوة مختصة بطابع هادئ، وتفاصيل بصرية ناعمة، وتجربة عربية راقية تحمل هوية مزن.' }}
        </div>

				<div class="hidden lg:block">
					<salla-social class="block mb-6"></salla-social>
				</div>

        <div class="mzn-footer__note">
          <span>قصة مزن</span>
          <p>نختار الإيقاع البصري الهادئ، ونمنح المنتج مساحته، ونبني تجربة متجر أقرب إلى التحرير الفاخر من الازدحام التجاري.</p>
        </div>

		    <div class="flex gap-4">
		      <salla-trust-badges {% if theme.settings.get('footer_is_dark') %} dark {% endif %}></salla-trust-badges>
          {% if store.settings.tax.number %}
            <div class="flex rtl:space-x-reverse space-x-2 items-end">
              {% if store.settings.tax.certificate %}
                <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/" alt="{{ store.settings.tax.number }}">
                  <img width="40" height="50" src="{{'images/tax.png' | cdn(70,70)}}" loading="lazy" class="w-10 rounded-sm hover:opacity-80 transition-opacity" alt="value added tax">
                </a>
              {% endif %}
              <div>
                <p class="text-sm text-text-grey mb-1">{{ trans('common.elements.tax_number') }}</p>
                <b class="text-sm">{{ store.settings.tax.number }}</b>
              </div>
            </div>

            {% if store.settings.tax.certificate %}
              <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                <div class="flex justify-center max-w-full">
                  <img class="w-full" loading="lazy"
                  data-src="{{ store.settings.tax.certificate }}"
                  alt="{{ store.settings.tax.number }}"/>
                </div>
              </salla-modal>
            {% endif %}
          {% endif %}
        </div>
      </div>

			<div class="mzn-footer__column">
				<h3>مختارات مزن</h3>
				<salla-menu source="footer"></salla-menu>
			</div>

			<div class="mzn-footer__column">
				<salla-contacts></salla-contacts>

				<div class="lg:hidden contact-social">
					<salla-social></salla-social>
				</div>
			</div>

			<salla-apps-icons class="lg:col-span-2 rtl:lg:pr-20 ltr:lg:pl-20"></salla-apps-icons>

		</div>
	</div>

	<div class="md:flex items-center justify-between py-4 container text-center mzn-footer__legal">
		<span class="text-sm copyright-text">{% hook copyright %}</span>
		<salla-payments></salla-payments>
	</div>
</footer>
