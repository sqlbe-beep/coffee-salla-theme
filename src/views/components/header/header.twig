{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
{% set important_links = theme.settings.get('important_links') %}
<header class="store-header mzn-header">
  <div class="top-navbar mzn-header__topbar">
    <div class="container mzn-header__topbar-inner">
      <div class="flex-1 flex items-center gap-2">
          {% if important_links %}
            <salla-menu source="footer" topnav></salla-menu>
          {% endif %}

          <div class="header-buttons">
              {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                  <button type="button" onclick="salla.event.dispatch('localization::open')" class="btn--rounded-gray basis-0">
                      <span>{{ user.language.name }}</span>
                      <span class="mx-1.5">|</span> <span>{{ currency.symbol }}</span>
                  </button>
                  <salla-localization-modal></salla-localization-modal>
              {% endif %}
          </div>

          {% if store.scope %}
              <button class="btn--rounded-gray"
                      onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                  <i class="sicon-location rtl:ml-1 ltr:mr-1"></i> {{ store.scope.name }}
              </button>
          {% endif %}

          <div class="header-search flex-1 mzn-header__search">
            <salla-search inline oval height="36"></salla-search>
          </div>
      </div>

      <div class="mzn-header__contacts">
        <salla-contacts is-header></salla-contacts>
      </div>
    </div>
  </div>

  <div id="mainnav" class="main-nav-container mzn-header__shell shadow-default bg-white flex items-center">
      <div class="inner bg-inherit w-full">
          <div class="container">
              <div class="mzn-header__inner flex items-stretch justify-between relative">
                  <div class="flex items-center mzn-header__start">
                      <a class="mzn-header__burger lg:hidden leading-none rtl:ml-4 ltr:mr-4" href="#mobile-menu" aria-label="Open-menu">
                        <i class="sicon-menu text-2xl"></i>
                      </a>
                      <a class="navbar-brand mzn-header__brand" href="{{ store.url }}">
                          {% if store.logo %}
                            <img fetchpriority="high" width="100%" height="100%" loading="eager" src="{{ store.logo|cdn(175) }}" alt="{{ store.name }} logo">
                          {% else %}
                            <span>{{ store.name|default('مزن') }}</span>
                          {% endif %}
                          {% if is_page('index') %}
                            <h1 class="sr-only">{{ store.name|default('مزن') }}</h1>
                          {% else %}
                            <h2 class="sr-only">{{ store.name|default('مزن') }}</h2>
                          {% endif %}
                      </a>
                      <div class="mzn-header__nav-wrap">
                        <custom-main-menu></custom-main-menu>
                      </div>
                  </div>
                  <div class="flex items-center justify-end my-2.5 mzn-header__actions">
                      {% if user.type=='user' %}
                        <salla-user-menu avatar-only show-header></salla-user-menu>
                      {% else %}
                          <button class="mzn-header__icon-button" aria-label="user-icon" onclick="salla.event.dispatch('login::open')">
                            <i class="sicon-user-circle"></i>
                          </button>
                      {% endif %}
                      <salla-cart-summary class="mzn-header__cart ml-4 rtl:ml-[unset] rtl:mr-4">
                        <i slot="icon" class="icon sicon-shopping-bag"></i>
                      </salla-cart-summary>
                  </div>
              </div>
          </div>
      </div>
  </div>
</header>
