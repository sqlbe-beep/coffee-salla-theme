<header class="mzn-header" id="mainnav">
    <div class="container mzn-header__inner">
        <button class="mzn-header__burger lg:hidden" type="button" aria-label="القائمة">
            <i class="sicon-menu"></i>
        </button>

        <nav class="mzn-header__nav" aria-label="التنقل الرئيسي">
            <a href="{{ routes.root_url }}" class="mzn-header__link">الرئيسية</a>
            <a href="{{ routes.products_url }}" class="mzn-header__link">المتجر</a>
            <a href="{{ routes.contact_url }}" class="mzn-header__link">تواصل</a>
        </nav>

        <a class="mzn-header__brand" href="{{ store.url }}" aria-label="{{ store.name }}">
            {% if store.logo %}
                <img fetchpriority="high" loading="eager" src="{{ store.logo|cdn(175) }}" alt="{{ store.name }} logo">
            {% else %}
                <span>{{ store.name|default('مزن') }}</span>
            {% endif %}
        </a>

        <div class="mzn-header__actions">
            <salla-search></salla-search>
            {% if user.type == 'user' %}
                <salla-user-menu avatar-only show-header></salla-user-menu>
            {% else %}
                <button class="mzn-header__icon-button" aria-label="حسابي" onclick="salla.event.dispatch('login::open')">
                    <i class="sicon-user-circle"></i>
                </button>
            {% endif %}
            <salla-cart-summary>
                <i slot="icon" class="sicon-shopping-bag"></i>
            </salla-cart-summary>
        </div>
    </div>
</header>
