        {
          "id": "hero_button_url",
          "type": "url",
          "label": { "ar": "رابط زر الهيرو", "en": "Hero Button URL" },
          "default": "/shop"
        }
      ]
    },
    {
      "id": "products",
      "label": {
        "ar": "قسم المنتجات",
        "en": "Products Section"
      },
      "settings": [
        {
          "id": "featured_heading",
          "type": "text",
          "label": { "ar": "عنوان قسم المنتجات", "en": "Products Section Heading" },
          "default": "مختارات مزن"
        },
        {
          "id": "featured_product_limit",
          "type": "range",
          "label": { "ar": "عدد المنتجات المعروضة", "en": "Featured Product Count" },
          "min": 3,
          "max": 12,
          "step": 3,
          "default": 6
        },
        {
          "id": "featured_show_price",
          "type": "checkbox",
          "label": { "ar": "إظهار السعر", "en": "Show Price" },
          "default": true
        },
        {
          "id": "featured_show_note",
          "type": "checkbox",
          "label": { "ar": "إظهار وصف النكهة", "en": "Show Flavor Note" },
          "default": true
        }
      ]
    },
    {
      "id": "story",
      "label": {
        "ar": "قسم القصة",
        "en": "Story Section"
      },
      "settings": [
        {
          "id": "story_enabled",
          "type": "checkbox",
          "label": { "ar": "تفعيل قسم القصة", "en": "Enable Story Section" },
          "default": true
        },
        {
          "id": "story_label",
          "type": "text",
          "label": { "ar": "تسمية القسم", "en": "Section Label" },
          "default": "قصة مزن"
        },
        {
          "id": "story_heading",
          "type": "text",
          "label": { "ar": "عنوان القسم", "en": "Section Heading" },
          "default": "من الأرض إلى الفنجان الأول"
        },
        {
          "id": "story_body",
          "type": "textarea",
          "label": { "ar": "نص القسم", "en": "Section Body" },
          "default": "في مزن، لا نبيع قهوة — نروي قصة أرض. كل حبة اخترناها بعناية، من مزارع يعمل أصحابها بشغف ومسؤولية على ارتفاعات تلمس الغيوم. تُحمص مختاراتنا بيدين واعيتين، لتبقى كل نكهة وفيّة لمصدرها."
        },
        {
          "id": "story_image",
          "type": "image",
          "label": { "ar": "صورة القسم", "en": "Section Image" },
          "default": ""
        },
        {
          "id": "story_cta_text",
          "type": "text",
          "label": { "ar": "نص الزر", "en": "CTA Text" },
          "default": "قصة مزن"
        },
        {
          "id": "story_cta_url",
          "type": "url",
          "label": { "ar": "رابط الزر", "en": "CTA URL" },
          "default": "/about"
        }
      ]
    },
    {
      "id": "footer",
      "label": {
        "ar": "التذييل",
        "en": "Footer"
      },
      "settings": [
        {
          "id": "footer_tagline",
          "type": "text",
          "label": { "ar": "الشعار النصي", "en": "Footer Tagline" },
