{
  "sections": [
    {
      "id": "colors",
      "label": {
        "ar": "الألوان",
        "en": "Colors"
      },
      "settings": [
        {
          "id": "color_background",
          "type": "color",
          "label": { "ar": "لون الخلفية", "en": "Background Color" },
          "default": "#f5f0eb"
        },
        {
          "id": "color_surface",
          "type": "color",
          "label": { "ar": "لون السطح", "en": "Surface Color" },
          "default": "#e2cdb0"
        },
        {
          "id": "color_text",
          "type": "color",
          "label": { "ar": "لون النص", "en": "Text Color" },
          "default": "#1a1610"
        },
        {
          "id": "color_muted",
          "type": "color",
          "label": { "ar": "لون النص الثانوي", "en": "Muted Text Color" },
          "default": "#6a5f52"
        },
        {
          "id": "color_primary",
          "type": "color",
          "label": { "ar": "اللون الأساسي", "en": "Primary Color" },
          "default": "#6f4e37"
        },
        {
          "id": "color_hero_bg",
          "type": "color",
          "label": { "ar": "خلفية الهيرو", "en": "Hero Background" },
          "default": "#231810"
        },
        {
          "id": "color_border",
          "type": "color",
          "label": { "ar": "لون الحدود", "en": "Border Color" },
          "default": "#e0d6cc"
        }
      ]
    },
    {
      "id": "typography",
      "label": {
        "ar": "الخطوط",
        "en": "Typography"
      },
      "settings": [
        {
          "id": "font_body",
          "type": "font",
          "label": { "ar": "خط النص", "en": "Body Font" },
          "default": "Noto Sans Arabic"
        },
        {
          "id": "font_size_base",
          "type": "range",
          "label": { "ar": "حجم الخط الأساسي", "en": "Base Font Size" },
          "min": 14,
          "max": 18,
          "step": 1,
          "default": 15
        }
      ]
    },
    {
      "id": "header",
      "label": {
        "ar": "الترويسة",
        "en": "Header"
      },
      "settings": [
        {
          "id": "logo",
          "type": "image",
          "label": { "ar": "الشعار", "en": "Logo" },
          "default": ""
        },
        {
          "id": "store_name",
          "type": "text",
          "label": { "ar": "اسم المتجر", "en": "Store Name" },
          "default": "مزن"
        },
        {
          "id": "announcement_enabled",
          "type": "checkbox",
          "label": { "ar": "تفعيل شريط الإعلانات", "en": "Enable Announcement Bar" },
          "default": true
        },
        {
          "id": "announcement_text",
          "type": "text",
          "label": { "ar": "نص الإعلان", "en": "Announcement Text" },
          "default": "شحن مجاني على الطلبات فوق ٢٠٠ ريال"
        }
      ]
    },
    {
      "id": "hero",
      "label": {
        "ar": "قسم الهيرو",
        "en": "Hero Section"
      },
      "settings": [
        {
          "id": "hero_image",
          "type": "image",
          "label": { "ar": "صورة الهيرو", "en": "Hero Image" },
          "default": ""
        },
        {
          "id": "hero_eyebrow",
          "type": "text",
